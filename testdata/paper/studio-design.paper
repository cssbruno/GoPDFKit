document @prescription-design:
  style @base:
    font: "Helvetica"
    size: 10pt
    line-height: 14pt
    color: "#243746"
  style @brand-name:
    style: "@base"
    size: 16pt
    line-height: 19pt
    bold: true
    color: "#14324A"
  style @header-meta:
    style: "@base"
    size: 8.5pt
    line-height: 11.5pt
    align: "right"
    color: "#526878"
  style @footer:
    style: "@base"
    size: 8pt
    line-height: 10pt
    align: "center"
    color: "#607787"
    border-top-width: 1pt
    border-color: "#B9CDD3"
    padding-top: 6pt
  style @eyebrow:
    style: "@base"
    size: 8.5pt
    line-height: 11pt
    bold: true
    color: "#1F7A72"
    margin-bottom: 3pt
  style @title:
    style: "@base"
    font: "Times"
    size: 30pt
    line-height: 34pt
    bold: true
    color: "#14324A"
  style @status-card:
    style: "@base"
    size: 9pt
    line-height: 12pt
    bold: true
    align: "right"
    color: "#17665F"
  style @section:
    style: "@base"
    size: 9.5pt
    line-height: 12.5pt
    bold: true
    color: "#FFFFFF"
    background: "#14324A"
    padding: 6pt
    margin-top: 10pt
    margin-bottom: 5pt
  style @meta-label:
    style: "@base"
    size: 8pt
    line-height: 11pt
    bold: true
    color: "#526878"
    background: "#F1F6F7"
    border-width: 1pt
    border-color: "#D4E1E4"
    padding: 6pt
  style @meta-value:
    style: "@base"
    size: 9.5pt
    line-height: 12pt
    bold: true
    color: "#1C3444"
    border-width: 1pt
    border-color: "#D4E1E4"
    padding: 6pt
  style @table-head:
    style: "@base"
    size: 8.5pt
    line-height: 11pt
    bold: true
    color: "#FFFFFF"
    background: "#1F7A72"
    border-width: 1pt
    border-color: "#17665F"
    padding: 6pt
  style @medicine:
    style: "@base"
    size: 10pt
    line-height: 13pt
    bold: true
    color: "#14324A"
    border-width: 1pt
    border-color: "#CFDCDF"
    padding: 7pt
  style @table-cell:
    style: "@base"
    size: 9pt
    line-height: 12pt
    color: "#324B5B"
    border-width: 1pt
    border-color: "#CFDCDF"
    padding: 7pt
  style @instruction:
    style: "@base"
    size: 9.5pt
    line-height: 13.5pt
    color: "#4B3B17"
    background: "#FFF8E7"
    border-left-width: 4pt
    border-color: "#E0A326"
    padding: 9pt
    margin-top: 8pt
  style @clinical-card:
    style: "@base"
    size: 8.5pt
    line-height: 12pt
    color: "#314C5C"
    background: "#F5F9FA"
    border-width: 1pt
    border-color: "#CFDCDF"
    border-radius: 4pt
    padding: 8pt
  style @signature:
    style: "@base"
    size: 8.5pt
    line-height: 12pt
    color: "#314C5C"
    border-top-width: 1pt
    border-color: "#7F98A6"
    padding-top: 7pt
  style @verification:
    style: "@base"
    size: 8.5pt
    line-height: 11pt
    align: "center"
    color: "#17665F"
    background: "#E9F6F3"
    border-width: 1pt
    border-color: "#A8D6CF"
    border-radius: 4pt
    padding: 7pt
