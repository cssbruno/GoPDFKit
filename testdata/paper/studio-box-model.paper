document @box-model:
  title: "Exact box model"
  language: "en"
  page @sheet:
    width: 240pt
    height: 160pt
    margin: 20pt
    body @content:
      paragraph @four-layers:
        font: "Helvetica"
        size: 12pt
        line-height: 16pt
        margin: 10pt
        margin-right: 14pt
        padding: 8pt
        padding-left: 12pt
        border-width: 3pt
        border-bottom-width: 5pt
        border-color: "#C43D32"
        background: "#EAF2FB"
        text: "Margin, border, padding, content"
