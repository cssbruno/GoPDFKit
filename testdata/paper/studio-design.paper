document @studio-design:
  style @body:
    font: "Helvetica"
    size: 12pt
    line-height: 18pt
  style @title:
    style: "@body"
    size: 28pt
    line-height: 34pt
  style @section:
    style: "@body"
    size: 16pt
    line-height: 22pt
  style @code:
    font: "Courier"
    size: 10pt
    line-height: 15pt
  style @second-page:
    style: "@body"
    size: 18pt
    line-height: 24pt
